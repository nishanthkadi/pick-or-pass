app/*.tsbuildinfo

# Private system prompt (full grading rules — not for public GitHub)
app/src/lib/prompts/system.private.txt
!app/src/lib/prompts/system.private.txt.example

# Eval run logs
eval/results/*
!eval/results/.gitignore
eval/feedback/*
!eval/feedback/.gitignore
eval/_review_export/

