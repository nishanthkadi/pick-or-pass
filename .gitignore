eval/dataset.jsonl
eval/drafts/**
!eval/drafts/.gitkeep
eval/golden/*
!eval/golden/listing-1.json
!eval/golden/listing-2.json
Eval_Seed_Examples.md

# Private listing photos (public examples: listing-1, listing-2 only)
assets/*
!assets/README.md
!assets/listing-1.jpg
!assets/listing-2.jpg
app/public/listings/*
!app/public/listings/listing-1.jpg
!app/public/listings/listing-2.jpg

