app/src/data/demos/listing-3.json
app/src/data/demos/listing-4.json
app/src/data/demos/listing-5.json
app/src/data/demos/listing-6.json
app/src/data/demos/listing-*.json
!app/src/data/demos/listing-1.json
!app/src/data/demos/listing-2.json
app/src/data/demos/manifest.local.json

